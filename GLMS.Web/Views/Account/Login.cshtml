@model GLMS.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Login — GLMS | TechMove Logistics</title>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta17/dist/css/tabler.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet" />
    <style>
            body {
                background: #0f172a;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 420px;
            }

            .brand-logo {
                font-size: 1.8rem;
                font-weight: 700;
                letter-spacing: -0.5px;
            }

            .brand-sub {
                font-size: 0.7rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
            }
    </style>
</head>
<body>
    <div class="login-card px-3">

        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="brand-logo text-white">
                <i class="ti ti-truck-delivery me-2 text-primary"></i>GLMS
            </div>
            <div class="brand-sub text-muted">TechMove Logistics</div>
        </div>

        <!-- Card -->
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">Welcome back</h2>
                <p class="text-muted text-center mb-4 small">Sign in to your account to continue</p>

                <form asp-action="Login" asp-controller="Account" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-3">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="ti ti-mail"></i>
                            </span>
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="admin@techmore.co.za"
                                   autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            Password
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="ti ti-lock"></i>
                            </span>
                            <input asp-for="Password"
                                   class="form-control"
                                   placeholder="••••••••"
                                   autocomplete="current-password"
                                   id="password-input" />
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="toggle-password"
                                    title="Show/hide password">
                                <i class="ti ti-eye" id="eye-icon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                            <span class="form-check-label text-muted">Remember me on this device</span>
                        </label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-login me-1"></i> Sign In
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            &copy; @DateTime.Now.Year TechMove Logistics — Internal System
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
    <script>
        // Toggle password visibility
        document.getElementById('toggle-password').addEventListener('click', function () {
        const input = document.getElementById('password-input');
        const icon = document.getElementById('eye-icon');
        if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('ti-eye', 'ti-eye-off');
        } else {
        input.type = 'password';
        icon.classList.replace('ti-eye-off', 'ti-eye');
        }
        });
    </script>
</body>
</html>
