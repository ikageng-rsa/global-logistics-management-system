@model Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Edit Client — @Model.Name</h3>
            </div>
            <div class="card-body">
                <form asp-controller="Clients" asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label required"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactDetails" class="form-label required"></label>
                        <input asp-for="ContactDetails" class="form-control" />
                        <span asp-validation-for="ContactDetails" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Region" class="form-label required"></label>
                        <input asp-for="Region" class="form-control" />
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i> Update Client
                        </button>
                        <a class="btn btn-ghost-secondary"
                           asp-controller="Clients" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
