@model ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Edit Service Request #@Model.Id</h3>
            </div>
            <div class="card-body">
                <form asp-controller="ServiceRequests" asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CostZAR" />

                    <div class="mb-3">
                        <input type="text"
                               class="form-control"
                               value="@($"{Model.Contract?.Client?.Name} — {Model.Contract?.ServiceLevel} ({Model.Contract?.StartDate:dd MMM yyyy} to {Model.Contract?.EndDate:dd MMM yyyy})")"
                               disabled />
                        <input type="hidden" asp-for="ContractId" />
                        <small class="text-muted">Contract cannot be changed after creation.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label required"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CostUSD" class="form-label required">Cost (USD)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="CostUSD" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <span asp-validation-for="CostUSD" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label required"></label>
                        <select asp-for="Status" class="form-select"
                                asp-items="Html.GetEnumSelectList<RequestStatus>()"></select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i> Update Request
                        </button>
                        <a class="btn btn-ghost-secondary"
                           asp-controller="ServiceRequests" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
