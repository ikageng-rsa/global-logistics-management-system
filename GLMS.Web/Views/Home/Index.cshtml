@{
    ViewData["Title"] = "Dashboard";
}

<div class="row row-deck row-cards mb-4">

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="subheader">Total Clients</div>
                </div>
                <div class="h1 mb-3">@ViewBag.TotalClients</div>
                <div class="d-flex mb-2">
                    <div>
                        <a class="btn btn-sm btn-outline-primary"
                           asp-controller="Clients" asp-action="Index">View All</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Contracts</div>
                <div class="h1 mb-3">@ViewBag.TotalContracts</div>
                <div class="d-flex gap-2">
                    <span class="badge bg-success-lt">@ViewBag.ActiveContracts Active</span>
                    <span class="badge bg-danger-lt">@ViewBag.ExpiredContracts Expired</span>
                    <span class="badge bg-warning-lt">@ViewBag.OnHoldContracts On Hold</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Service Requests</div>
                <div class="h1 mb-3">@ViewBag.TotalRequests</div>
                <div class="d-flex gap-2">
                    <span class="badge bg-warning-lt">@ViewBag.PendingRequests Pending</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Total Request Value</div>
                <div class="h1 mb-3">$@string.Format("{0:N2}", ViewBag.TotalValueUSD)</div>
                <div class="text-muted small">
                    R @string.Format("{0:N2}", ViewBag.TotalValueZAR) ZAR
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row row-cards">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Quick Actions</h3>
            </div>
            <div class="card-body">
                <div class="d-flex gap-3 flex-wrap">
                    <a class="btn btn-primary"
                        asp-controller="Clients" asp-action="Create">
                        <i class="ti ti-user-plus me-1"></i> Add Client
                    </a>
                    <a class="btn btn-secondary"
                           asp-controller="Contracts" asp-action="Create">
                        <i class="ti ti-file-plus me-1"></i> New Contract
                    </a>
                    <a class="btn btn-outline-secondary"
                           asp-controller="ServiceRequests" asp-action="Create">
                        <i class="ti ti-clipboard-plus me-1"></i> New Service Request
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
