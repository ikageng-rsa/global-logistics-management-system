<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>@ViewData["Title"] — GLMS | TechMove Logistics</title>

    <!-- Tabler CSS -->
    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/css/tabler.min.css" />
    <!-- Tabler Icons -->
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet" />

    <style>
            :root {
                --glms-accent: #0054a6;
                --glms-accent-hover: #003f7f;
            }

            /* Sidebar brand styling */
            .navbar-brand-image {
                height: 32px;
            }

            /* Active nav item accent */
            .nav-link.active {
                color: var(--glms-accent) !important;
                font-weight: 600;
            }

            /* Theme toggle button */
            #theme-toggle {
                cursor: pointer;
                border: none;
                background: transparent;
                padding: 0.25rem 0.5rem;
                border-radius: 0.375rem;
                transition: background 0.2s;
            }

            #theme-toggle:hover {
                background: rgba(0, 0, 0, 0.08);
            }

            [data-bs-theme="dark"] #theme-toggle:hover {
                background: rgba(255, 255, 255, 0.08);
            }

            /* Page transition */
            .page-wrapper {
                animation: fadeIn 0.2s ease-in;
                min-height:100dvh;
            }

            @@keyframes fadeIn {
                from { opacity: 0; transform: translateY(6px); }
                to   { opacity: 1; transform: translateY(0); }
            }
    </style>
</head>

<body class="antialiased">
    <div class="wrapper">

        <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
            <div class="container-fluid">

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <a href="/" class="navbar-brand navbar-brand-autodark">
                    <span class="fw-bold fs-4 text-white">
                        <i class="ti ti-truck-delivery me-2"></i>GLMS
                    </span>
                    <span class="d-block text-muted" style="font-size:0.7rem; letter-spacing:0.08em;">
                        TECHMORE LOGISTICS
                    </span>
                </a>

                <div class="collapse navbar-collapse" id="sidebar-menu">
                    <ul class="navbar-nav pt-lg-3">

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                                   href="/">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <i class="ti ti-home"></i>
                                </span>
                                <span class="nav-link-title">Dashboard</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
                                   asp-controller="Clients" asp-action="Index">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <i class="ti ti-users"></i>
                                </span>
                                <span class="nav-link-title">Clients</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")"
                                   asp-controller="Contracts" asp-action="Index">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <i class="ti ti-file-text"></i>
                                </span>
                                <span class="nav-link-title">Contracts</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequests" ? "active" : "")"
                                   asp-controller="ServiceRequests" asp-action="Index">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <i class="ti ti-clipboard-list"></i>
                                </span>
                                <span class="nav-link-title">Service Requests</span>
                            </a>
                        </li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                                    asp-controller="Users" asp-action="Index">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-users-group"></i>
                                    </span>
                                    <span class="nav-link-title">User Management</span>
                                </a>
                            </li>
                        }

                    </ul>

                    <div class="mt-auto pb-3">
                        <div class="d-flex align-items-center px-3 gap-2">
                            <i class="ti ti-user-circle text-muted"></i>
                            <div>
                                <div class="text-white small">@User.Identity?.Name</div>
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge bg-primary" style="font-size:0.6rem;">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary" style="font-size:0.6rem;">User</span>
                                }
                            </div>
                            <form asp-action="Logout" asp-controller="Account" method="post" class="ms-auto">
                                <button type="submit" class="btn btn-sm btn-ghost-danger" title="Sign out">
                                    <i class="ti ti-logout"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="page-wrapper">

            <div class="page-header d-print-none">
                <div class="container-xl">
                    <div class="row g-2 align-items-center">
                        <div class="col">
                            <h2 class="page-title">@ViewData["Title"]</h2>
                        </div>
                        <div class="col-auto ms-auto">
                            <button id="theme-toggle" title="Toggle theme">
                                <i class="ti ti-sun" id="icon-light"></i>
                                <i class="ti ti-moon d-none" id="icon-dark"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="page-body">
                <div class="container-xl">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="ti ti-circle-check me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </div>

            <footer class="footer footer-transparent d-print-none">
                <div class="container-xl">
                    <div class="row text-center align-items-center">
                        <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item">
                                    &copy; @DateTime.Now.Year GLMS — TechMove Logistics
                                </li>
                                <li class="list-inline-item">
                                    <span class="badge bg-blue-lt">v1.0</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>

        </div>
    </div>

    <script
        src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/js/tabler.min.js"></script>

    <script>
        const html       = document.documentElement;
        const iconLight  = document.getElementById('icon-light');
        const iconDark   = document.getElementById('icon-dark');
        const THEME_KEY  = 'glms-theme';

        function applyTheme(theme) {
            html.setAttribute('data-bs-theme', theme);
            if (theme === 'dark') {
            iconLight.classList.add('d-none');
            iconDark.classList.remove('d-none');
            } else {
            iconDark.classList.add('d-none');
            iconLight.classList.remove('d-none');
            }
            localStorage.setItem(THEME_KEY, theme);
        }

        const savedTheme = localStorage.getItem(THEME_KEY) || 'light';
        applyTheme(savedTheme);

        document.getElementById('theme-toggle').addEventListener('click', () => {
        const current = html.getAttribute('data-bs-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
